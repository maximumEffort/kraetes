---

<section id="contact" class="py-24 bg-light">
  <div class="max-w-3xl mx-auto px-6">
    <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-3">Contact</p>
    <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">
      Let's talk
    </h2>
    <p class="text-muted text-lg mb-12">
      Have a project in mind, or just want to connect? Drop me a message.
    </p>

    <div class="grid md:grid-cols-5 gap-12">
      <!-- Form -->
      <div class="md:col-span-3">
        <!-- Success state -->
        <div id="form-success" class="hidden text-center py-12">
          <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-primary mb-2">Sent!</h3>
          <p class="text-muted">I'll get back to you soon.</p>
        </div>

        <!-- Error banner -->
        <div id="form-error" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700" role="alert">
          Something went wrong. Please try again or email me directly.
        </div>

        <form class="space-y-5" id="contact-form" novalidate>
          <div>
            <label for="name" class="block text-sm font-medium text-dark mb-2">Name <span class="text-red-500" aria-hidden="true">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all text-sm"
              placeholder="Your name"
              aria-required="true"
              aria-describedby="name-error"
            />
            <p id="name-error" class="hidden mt-1 text-xs text-red-600" role="alert">Please enter your name.</p>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-dark mb-2">Email <span class="text-red-500" aria-hidden="true">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all text-sm"
              placeholder="you@example.com"
              aria-required="true"
              aria-describedby="email-error"
            />
            <p id="email-error" class="hidden mt-1 text-xs text-red-600" role="alert">Please enter a valid email address.</p>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-dark mb-2">Message <span class="text-red-500" aria-hidden="true">*</span></label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all text-sm resize-none"
              placeholder="What's on your mind?"
              aria-required="true"
              aria-describedby="message-error"
            ></textarea>
            <p id="message-error" class="hidden mt-1 text-xs text-red-600" role="alert">Please enter your message.</p>
          </div>
          <!-- Honeypot -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <button
            type="submit"
            id="submit-btn"
            class="px-8 py-3.5 bg-primary text-white font-medium rounded-lg hover:bg-accent transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <span id="submit-label">Send Message</span>
            <span id="submit-loading" class="hidden">Sending...</span>
          </button>
        </form>
      </div>

      <!-- Contact info -->
      <div class="md:col-span-2 space-y-6">
        <div>
          <div class="text-sm text-muted mb-1">Email</div>
          <a href="mailto:amr.sarhan52@gmail.com" class="text-primary font-medium hover:text-highlight transition-colors">
            amr.sarhan52@gmail.com
          </a>
        </div>
        <div>
          <div class="text-sm text-muted mb-1">WhatsApp</div>
          <a href="https://wa.me/971589519085" target="_blank" rel="noopener noreferrer" class="text-primary font-medium hover:text-highlight transition-colors">
            +971 58 951 9085
          </a>
        </div>
        <div>
          <div class="text-sm text-muted mb-1">Location</div>
          <div class="text-primary font-medium">Dubai, UAE</div>
        </div>
        <div>
          <div class="text-sm text-muted mb-1">Connect</div>
          <div class="flex items-center gap-4 mt-2">
            <a href="https://wa.me/971589519085" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-primary transition-colors" aria-label="WhatsApp">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/amr-sarhan52" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-primary transition-colors" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://github.com/maximumEffort" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-primary transition-colors" aria-label="GitHub">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const FORMSPREE_ENDPOINT = "https://formspree.io/f/xpwzojkv";

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const submitLabel = document.getElementById("submit-label");
  const submitLoading = document.getElementById("submit-loading");
  const successEl = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");

  function showFieldError(id: string, show: boolean) {
    const el = document.getElementById(id);
    if (el) el.classList.toggle("hidden", !show);
  }

  function validateForm(data: FormData): boolean {
    let valid = true;
    const name = (data.get("name") as string | null)?.trim() ?? "";
    const email = (data.get("email") as string | null)?.trim() ?? "";
    const message = (data.get("message") as string | null)?.trim() ?? "";
    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    showFieldError("name-error", !name);
    showFieldError("email-error", !email || !emailRe.test(email));
    showFieldError("message-error", !message);

    if (!name || !email || !emailRe.test(email) || !message) valid = false;
    return valid;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl?.classList.add("hidden");

    const data = new FormData(form);
    if (!validateForm(data)) return;

    if (submitBtn) submitBtn.disabled = true;
    submitLabel?.classList.add("hidden");
    submitLoading?.classList.remove("hidden");

    try {
      const res = await fetch(FORMSPREE_ENDPOINT, {
        method: "POST",
        body: data,
        headers: { Accept: "application/json" },
      });

      if (res.ok) {
        form.classList.add("hidden");
        successEl?.classList.remove("hidden");
      } else {
        throw new Error("Server error");
      }
    } catch {
      errorEl?.classList.remove("hidden");
      if (submitBtn) submitBtn.disabled = false;
      submitLabel?.classList.remove("hidden");
      submitLoading?.classList.add("hidden");
    }
  });
</script>
