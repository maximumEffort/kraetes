---

---

<section id="contact" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16">
      <div>
        <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-3">Contact</p>
        <h2 class="text-3xl md:text-4xl font-bold text-primary mb-6">
          Let's build something great together
        </h2>
        <p class="text-muted leading-relaxed mb-8">
          Whether you have a specific project in mind or just want to explore what's possible,
          I'd love to hear from you. Every great transformation starts with a conversation.
        </p>

        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-primary/5 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <div class="text-sm text-muted">Email</div>
              <a href="mailto:amr.sarhan52@gmail.com" class="text-primary font-medium hover:text-highlight transition-colors">
                amr.sarhan52@gmail.com
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-primary/5 flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <div class="text-sm text-muted">Location</div>
              <div class="text-primary font-medium">Dubai, UAE (Available Worldwide)</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <!-- Success state -->
        <div id="form-success" class="hidden text-center py-12">
          <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-primary mb-2">Message sent!</h3>
          <p class="text-muted">Thank you for reaching out. I'll get back to you within 24 hours.</p>
        </div>

        <!-- Error banner -->
        <div id="form-error" class="hidden mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700" role="alert">
          Something went wrong. Please try again or email me directly at <a href="mailto:amr.sarhan52@gmail.com" class="underline font-medium">amr.sarhan52@gmail.com</a>.
        </div>

        <noscript>
          <p class="mb-4 p-4 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-800">
            Please enable JavaScript to use this form, or email me directly at
            <a href="mailto:amr.sarhan52@gmail.com" class="underline font-medium">amr.sarhan52@gmail.com</a>.
          </p>
        </noscript>

        <form class="space-y-5" id="contact-form" novalidate>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium text-dark mb-2">Name <span class="text-red-500" aria-hidden="true">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all text-sm"
                placeholder="Your name"
                aria-required="true"
                aria-describedby="name-error"
              />
              <p id="name-error" class="hidden mt-1 text-xs text-red-600" role="alert">Please enter your name.</p>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-dark mb-2">Email <span class="text-red-500" aria-hidden="true">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all text-sm"
                placeholder="you@company.com"
                aria-required="true"
                aria-describedby="email-error"
              />
              <p id="email-error" class="hidden mt-1 text-xs text-red-600" role="alert">Please enter a valid email address.</p>
            </div>
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-dark mb-2">Subject</label>
            <select
              id="subject"
              name="subject"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all text-sm"
            >
              <option value="">What can I help with?</option>
              <option value="Digital Transformation Consulting">Digital Transformation Consulting</option>
              <option value="Business Automation">Business Automation</option>
              <option value="ERP Implementation">ERP Implementation</option>
              <option value="Systems Integration">Systems Integration</option>
              <option value="General Inquiry">General Inquiry</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-dark mb-2">Message <span class="text-red-500" aria-hidden="true">*</span></label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all text-sm resize-none"
              placeholder="Tell me about your project..."
              aria-required="true"
              aria-describedby="message-error"
            ></textarea>
            <p id="message-error" class="hidden mt-1 text-xs text-red-600" role="alert">Please enter your message.</p>
          </div>
          <!-- Honeypot: hidden field to catch bots (Formspree _gotcha) -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <button
            type="submit"
            id="submit-btn"
            class="w-full px-8 py-3.5 bg-primary text-white font-medium rounded-lg hover:bg-accent transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <span id="submit-label">Send Message</span>
            <span id="submit-loading" class="hidden">Sending…</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const FORMSPREE_ENDPOINT = "https://formspree.io/f/xpwzojkv";

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const submitLabel = document.getElementById("submit-label");
  const submitLoading = document.getElementById("submit-loading");
  const successEl = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");

  function showFieldError(id: string, show: boolean) {
    const el = document.getElementById(id);
    if (el) el.classList.toggle("hidden", !show);
  }

  function validateForm(data: FormData): boolean {
    let valid = true;
    const name = (data.get("name") as string | null)?.trim() ?? "";
    const email = (data.get("email") as string | null)?.trim() ?? "";
    const message = (data.get("message") as string | null)?.trim() ?? "";
    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    showFieldError("name-error", !name);
    showFieldError("email-error", !email || !emailRe.test(email));
    showFieldError("message-error", !message);

    if (!name || !email || !emailRe.test(email) || !message) valid = false;
    return valid;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl?.classList.add("hidden");

    const data = new FormData(form);
    if (!validateForm(data)) return;

    if (submitBtn) submitBtn.disabled = true;
    submitLabel?.classList.add("hidden");
    submitLoading?.classList.remove("hidden");

    try {
      const res = await fetch(FORMSPREE_ENDPOINT, {
        method: "POST",
        body: data,
        headers: { Accept: "application/json" },
      });

      if (res.ok) {
        form.classList.add("hidden");
        successEl?.classList.remove("hidden");
      } else {
        throw new Error("Server error");
      }
    } catch {
      errorEl?.classList.remove("hidden");
      if (submitBtn) submitBtn.disabled = false;
      submitLabel?.classList.remove("hidden");
      submitLoading?.classList.add("hidden");
    }
  });
</script>
