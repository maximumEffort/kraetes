<section id="work" class="py-24">
  <div class="max-w-3xl mx-auto px-6">
    <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-3">Work</p>
    <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">
      Where I've made an impact
    </h2>
    <p class="text-muted text-lg mb-12">
      A few highlights from 12+ years of enterprise work across the MENA region.
    </p>

    <div class="space-y-8">
      {highlights.map((item) => (
        <div class="group p-6 md:p-8 rounded-2xl border border-gray-100 hover:border-primary/20 hover:shadow-md transition-all duration-300">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-3">
            <div>
              <h3 class="text-xl font-semibold text-primary">{item.title}</h3>
              <p class="text-sm font-medium text-accent">{item.role}</p>
            </div>
            <span class="text-xs font-medium text-muted bg-light px-3 py-1 rounded-full shrink-0">
              {item.context}
            </span>
          </div>
          <p class="text-muted leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 p-6 bg-light rounded-2xl">
      <h3 class="text-sm font-semibold text-primary uppercase tracking-wide mb-3">Certifications</h3>
      <div class="space-y-2">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-highlight mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm text-dark">Oracle Global Human Resources Cloud 2019 — Certified Implementation Specialist</span>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-highlight mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm text-dark">Oracle Payroll Cloud 2019 — Certified Implementation Specialist</span>
        </div>
      </div>
    </div>
  </div>
</section>
