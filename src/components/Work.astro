    title: "Digital Dubai Authority",
    role: "Dedicated SME — Oracle EBS",
    description:
      "Full-time operation support and system optimization for one of Dubai's key digital government authorities. Managing HR modules, driving HCM strategy, and keeping critical systems running for a city-scale operation.",
    context: "Government | Dubai, UAE",
  },
  {
    title: "Al Khayyat Investments",
    role: "HCM Lead — Oracle Fusion Cloud",
    description:
      "Led the complete Oracle Fusion Cloud HCM implementation from requirements gathering through go-live for a major Dubai-based conglomerate. Full lifecycle ownership as HCM Lead.",
    context: "Private Sector | Dubai, UAE",
  },
  {
    title: "Oracle — Advanced Customer Services",
    role: "Senior ACS Engineer",
    description:
      "Three years at Oracle serving major clients across the region — National Bank of Egypt, Department of Finance Abu Dhabi, National Water Company Saudi Arabia, Oman Aviation, and more. Deep enterprise support at scale.",
    context: "Enterprise | Multi-country",
  },
  {
