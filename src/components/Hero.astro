---

---

<section id="hero" class="min-h-screen flex items-center pt-20">
  <div class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-4">
        Digital Transformation &amp; AI Automation
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-primary leading-tight mb-6">
        Transform your business<br />
        <span class="text-accent">with AI that works.</span>
      </h1>
      <p class="text-lg text-muted leading-relaxed mb-8 max-w-lg">
        I combine 12+ years of enterprise systems expertise with cutting-edge AI agents
        and automation to help businesses eliminate manual work, make smarter decisions,
        and scale without adding headcount.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="#contact"
          class="px-8 py-3.5 bg-primary text-white font-medium rounded-lg hover:bg-accent transition-colors"
        >
          Book a Discovery Call
        </a>
        <a
          href="#services"
          class="px-8 py-3.5 border border-gray-300 text-primary font-medium rounded-lg hover:border-primary transition-colors"
        >
          See How It Works
        </a>
      </div>

      <!-- Trust signals -->
      <div class="mt-12 flex flex-wrap items-center gap-6 text-sm text-muted">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-highlight" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span>Oracle Certified</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-highlight" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838l-3.14 1.346L10 11.684l6.644-2.845a1 1 0 000-1.838l-7-3z" />
            <path d="M3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762z" />
          </svg>
          <span>20+ Enterprise Clients</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-highlight" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
          <span>AI-Powered Solutions</span>
        </div>
      </div>
    </div>

    <!-- Visual element -->
    <div class="hidden md:flex justify-center">
      <div class="relative">
        <div class="w-80 h-80 rounded-full bg-gradient-to-br from-primary/5 to-highlight/10 flex items-center justify-center">
          <div class="w-64 h-64 rounded-full bg-gradient-to-br from-primary/10 to-accent/10 flex items-center justify-center">
            <div class="text-center px-6">
              <svg class="w-16 h-16 text-primary mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
              </svg>
              <div class="text-lg font-bold text-primary">AI + Enterprise</div>
              <div class="text-sm text-muted mt-1">Where expertise meets</div>
              <div class="text-sm text-muted">intelligent automation</div>
            </div>
          </div>
        </div>
        <!-- Floating badges -->
        <div class="absolute top-4 right-0 bg-white shadow-lg rounded-lg px-4 py-2 text-sm font-medium text-primary">
          AI Agents
        </div>
        <div class="absolute bottom-8 -left-4 bg-white shadow-lg rounded-lg px-4 py-2 text-sm font-medium text-highlight">
          Automation
        </div>
        <div class="absolute top-1/2 -right-8 bg-white shadow-lg rounded-lg px-4 py-2 text-sm font-medium text-accent">
          ERP &amp; HCM
        </div>
      </div>
    </div>
  </div>
</section>
