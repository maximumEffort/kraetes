---

<section id="services" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-3">Services</p>
      <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">
        How I help businesses grow
      </h2>
      <p class="text-muted max-w-2xl mx-auto">
        Every engagement starts with understanding your business. Then I design and
        deliver solutions that create measurable impact.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="group p-8 rounded-2xl border border-gray-100 hover:border-primary/20 hover:shadow-lg transition-all duration-300">
          <div class="text-primary mb-5 group-hover:text-highlight transition-colors" set:html={service.icon} />
          <h3 class="text-xl font-semibold text-primary mb-3">{service.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
