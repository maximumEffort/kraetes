    description: "End-to-end roadmaps to move your business from legacy processes to modern, AI-powered systems. I assess where you are, design where you need to be, and execute the transition without disruption.",
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 0015 0m-15 0a7.5 7.5 0 1115 0m-15 0H3m16.5 0H21m-1.5 0H12m-8.457 3.077l1.41-.513m14.095-5.13l1.41-.513M5.106 17.785l1.15-.964m11.49-9.642l1.149-.964M7.501 19.795l.75-1.3m7.5-12.99l.75-1.3m-6.063 16.658l.26-1.477m2.605-14.772l.26-1.477m0 17.726l-.26-1.477M10.698 4.614l-.26-1.477M16.5 19.794l-.75-1.299M7.5 4.205L12 12m6.894 5.785l-1.149-.964M6.256 7.178l-1.15-.964m15.352 8.864l-1.41-.513M4.954 9.435l-1.41-.514M12.002 12l-3.75 6.495" /></svg>`,
    title: "Workflow Automation",
    description: "Identify bottlenecks, eliminate manual work, and implement automations that save hundreds of hours. From approval chains and document processing to cross-system data flows that just run.",
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>`,
    title: "ERP & HCM Modernization",
    description: "Expert Oracle Fusion Cloud and EBS consulting — from needs assessment and migration to AI-enhanced implementations. 12+ years and 20+ enterprise deployments across the MENA region.",
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>`,
    title: "Systems Integration & APIs",
    description: "Connect your scattered tools into one intelligent ecosystem. REST APIs, data pipelines, and AI-powered middleware that unify your HR, Finance, and Operations systems into a single source of truth.",
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>`,
    title: "AI-Powered Analytics & Reporting",
    description: "Transform raw business data into actionable insights with AI-driven dashboards and automated reporting. Natural language queries, predictive analytics, and executive summaries that write themselves.",
  },
];
---

<section id="services" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-3">Services</p>
      <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">
        Enterprise expertise meets AI innovation
      </h2>
      <p class="text-muted max-w-2xl mx-auto">
        I don't just implement technology — I architect intelligent systems that learn,
        adapt, and multiply your team's output. Every solution is built on a foundation
        of 12+ years in enterprise operations.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map((service) => (
        <div class="group p-8 rounded-2xl border border-gray-100 hover:border-primary/20 hover:shadow-lg transition-all duration-300">
          <div class="text-primary mb-5 group-hover:text-highlight transition-colors" set:html={service.icon} />
          <h3 class="text-xl font-semibold text-primary mb-3">{service.title}</h3>
          <p class="text-muted text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
