---

<section id="story" class="py-20">
  <div class="max-w-3xl mx-auto px-6">
    <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-3">My Story</p>
    <h2 class="text-3xl md:text-4xl font-bold text-primary mb-8">
      In 60 seconds
    </h2>
    <div class="relative w-full rounded-2xl overflow-hidden shadow-lg" style="padding-bottom: 56.25%;">
      <iframe
        src="https://www.youtube.com/embed/9_ojNPMPvdU?rel=0&modestbranding=1&color=white"
        title="Amr Sarhan — My Story"
        class="absolute inset-0 w-full h-full"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>
