---
const experience = [
  {
    role: "Sr. Principal Specialist",
    company: "Dicetek LLC / Digital Dubai Authority",
    location: "Dubai, UAE",
    period: "Jun 2024 — Present",
    dateFrom: "2024-06",
    dateTo: undefined as string | undefined,
    description: "Dedicated SME providing full-time operation support for Digital Dubai Authority on Oracle E-Business Suite. Leading HCM strategy and system optimization for a major government entity.",
  },
  {
    role: "Sr. Principal Specialist",
    company: "Mastek",
    location: "Dubai, UAE",
    period: "Jul 2021 — May 2024",
    dateFrom: "2021-07",
    dateTo: "2024-05",
    description: "Led Oracle Fusion Cloud HCM implementations for Al Khayyat Investments (Dubai) as HCM Lead. Provided advanced support for Zamil Group Holding Company (Saudi Arabia) on Oracle Fusion Cloud. Augmented resource for Digital Dubai Authority on Oracle EBS.",
  },
  {
    role: "Senior ACS Engineer",
    company: "Oracle",
    location: "Egypt",
    period: "Aug 2018 — Jun 2021",
    dateFrom: "2018-08",
    dateTo: "2021-06",
    description: "Senior Advanced Customer Services engineer at Oracle, serving major clients including National Bank of Egypt, Department of Finance Abu Dhabi, National Water Company Saudi Arabia, Oman Aviation, Airports Company South Africa, E-Government Program Yesser, and Kuwait Integrated Petroleum Industries.",
  },
  {
    role: "Techno-Functional Specialist",
    company: "Evolutionary Systems Consultancy",
    location: "Egypt",
    period: "Mar 2016 — Jul 2018",
    dateFrom: "2016-03",
    dateTo: "2018-07",
    description: "Delivered Oracle EBS implementations for Abdul Latif Jameel, Almoosa Specialist Hospital, Kuwait Credit Bank, and Ministry of Foreign Affairs Abu Dhabi. Handled full lifecycle from requirements to go-live.",
  },
  {
    role: "Functional Specialist",
    company: "Sphere Consulting",
    location: "Egypt",
    period: "Jan 2013 — Feb 2016",
    dateFrom: "2013-01",
    dateTo: "2016-02",
    description: "Oracle HCM functional consulting for Kuwait University (upgrade) and Hamad Medical Corporation Qatar (support). Built foundation in enterprise HR system implementation.",
  },
];

const certifications = [
  "Oracle Global Human Resources Cloud 2019 — Certified Implementation Specialist",
  "Oracle Payroll Cloud 2019 — Certified Implementation Specialist",
];
---

<section id="resume" class="py-24 bg-light">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-3">Resume</p>
      <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">
        Professional journey
      </h2>
      <p class="text-muted max-w-2xl mx-auto">
        12+ years progressing from functional consulting to senior principal roles,
        with a 3-year tenure at Oracle itself.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-12">
      <!-- Experience timeline -->
      <div class="md:col-span-2">
        <h3 class="text-lg font-semibold text-primary mb-8">Experience</h3>
        <div class="space-y-8">
          {experience.map((item) => (
            <div class="relative pl-8 border-l-2 border-primary/20">
              <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-white border-2 border-highlight" />
              <div class="text-xs font-medium text-highlight mb-1">
                <time datetime={item.dateFrom}>{item.period.split(" — ")[0]}</time>
                {" — "}
                {item.dateTo
                  ? <time datetime={item.dateTo}>{item.period.split(" — ")[1]}</time>
                  : <span>{item.period.split(" — ")[1]}</span>
                }
              </div>
              <h4 class="text-lg font-semibold text-primary">{item.role}</h4>
              <div class="text-sm font-medium text-accent mb-2">{item.company} — {item.location}</div>
              <p class="text-muted text-sm leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Certifications & Skills -->
      <div>
        <h3 class="text-lg font-semibold text-primary mb-8">Oracle Certifications</h3>
        <div class="space-y-3">
          {certifications.map((cert) => (
            <div class="flex items-start gap-3 p-3 bg-white rounded-lg">
              <svg class="w-5 h-5 text-highlight mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-dark">{cert}</span>
            </div>
          ))}
        </div>

        <h3 class="text-lg font-semibold text-primary mt-10 mb-4">Oracle Fusion</h3>
        <div class="flex flex-wrap gap-2 mb-6">
          {["Core HR", "Workforce Deployment", "Global Payroll", "Absence Management", "Performance Management", "Goal Management"].map((tech) => (
            <span class="text-xs font-medium px-3 py-1.5 bg-white border border-gray-200 rounded-full text-muted hover:border-primary hover:text-primary transition-colors">
              {tech}
            </span>
          ))}
        </div>

        <h3 class="text-lg font-semibold text-primary mt-6 mb-4">Oracle EBS</h3>
        <div class="flex flex-wrap gap-2 mb-6">
          {["Oracle HR", "Oracle Payroll", "SSHR", "iRecruitment", "PMS", "AME"].map((tech) => (
            <span class="text-xs font-medium px-3 py-1.5 bg-white border border-gray-200 rounded-full text-muted hover:border-primary hover:text-primary transition-colors">
              {tech}
            </span>
          ))}
        </div>

        <h3 class="text-lg font-semibold text-primary mt-6 mb-4">Technical Skills</h3>
        <div class="flex flex-wrap gap-2">
          {["SQL", "PL/SQL", "XML Publisher", "OTBI", "Groovy Scripting", "Forms & OAF", "RetroPay", "Costing", "Advanced Excel"].map((tech) => (
            <span class="text-xs font-medium px-3 py-1.5 bg-white border border-gray-200 rounded-full text-muted hover:border-primary hover:text-primary transition-colors">
              {tech}
            </span>
          ))}
        </div>

        <h3 class="text-lg font-semibold text-primary mt-10 mb-4">Languages</h3>
        <div class="space-y-2">
          <div class="flex justify-between text-sm">
            <span class="text-dark">Arabic</span>
            <span class="text-muted">Native</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-dark">English</span>
            <span class="text-muted">Fluent</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
