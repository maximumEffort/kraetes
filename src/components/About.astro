---

---

<section id="about" class="py-24 bg-light">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-3">About</p>
        <h2 class="text-3xl md:text-4xl font-bold text-primary mb-6">
          From enterprise systems to empowering businesses
        </h2>
        <p class="text-muted leading-relaxed mb-4">
          I'm Amr Sarhan, a Senior Principal Oracle HRMS ERP Specialist with over 15 years of
          experience transforming how enterprises operate. I've seen firsthand how the right
          technology can turn complexity into clarity and manual work into automated efficiency.
        </p>
        <p class="text-muted leading-relaxed mb-4">
          Now I'm channeling that expertise into something bigger: helping businesses of all
          sizes digitalize their operations, automate their workflows, and build the systems
          they need to scale and thrive.
        </p>
        <p class="text-muted leading-relaxed mb-8">
          Whether you're a growing business drowning in spreadsheets or an enterprise ready to
          modernize, I bring the strategic vision and hands-on expertise to make it happen.
        </p>

        <div class="grid grid-cols-3 gap-6">
          <div>
            <div class="text-3xl font-bold text-primary">15+</div>
            <div class="text-sm text-muted mt-1">Years of Experience</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-primary">50+</div>
            <div class="text-sm text-muted mt-1">Projects Delivered</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-primary">100%</div>
            <div class="text-sm text-muted mt-1">Client Focused</div>
          </div>
        </div>
      </div>

      <!-- Skills / Expertise -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-primary mb-6">Core Expertise</h3>
        {[
          { skill: "Oracle HRMS / ERP Systems", level: "98%" },
          { skill: "Business Process Automation", level: "95%" },
          { skill: "Digital Transformation Strategy", level: "92%" },
          { skill: "Systems Integration", level: "90%" },
          { skill: "Data Migration & Analytics", level: "88%" },
        ].map(({ skill, level }) => (
          <div>
            <div class="flex justify-between text-sm mb-2">
              <span class="font-medium text-dark">{skill}</span>
              <span class="text-muted">{level}</span>
            </div>
            <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
              <div
                class="h-full bg-gradient-to-r from-primary to-accent rounded-full"
                style={`width: ${level}`}
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
