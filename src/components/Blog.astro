---
const posts = [
  {
    title: "Why Every Business Needs a Digital Transformation Strategy in 2026",
    excerpt: "The companies that thrive aren't the ones with the biggest budgets — they're the ones that systematically replace friction with automation.",
    date: "April 2026",
    readTime: "5 min read",
    category: "Strategy",
    slug: "/blog/digital-transformation-strategy-2026",
  },
  {
    title: "The Hidden Cost of Manual Processes",
    excerpt: "That spreadsheet your team updates every Monday? It's costing you more than you think. Here's how to calculate the true price of manual work.",
    date: "April 2026",
    readTime: "4 min read",
    category: "Automation",
    slug: "/blog/hidden-cost-manual-processes",
  },
  {
    title: "Oracle HRMS: Lessons from 15 Years in the Trenches",
    excerpt: "After implementing Oracle HRMS across dozens of organizations, here are the patterns that separate successful deployments from costly failures.",
    date: "March 2026",
    readTime: "7 min read",
    category: "ERP",
    slug: "/blog/oracle-hrms-lessons",
  },
];
---

<section id="blog" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-highlight font-medium text-sm tracking-wide uppercase mb-3">Blog</p>
      <h2 class="text-3xl md:text-4xl font-bold text-primary mb-4">
        Insights & perspectives
      </h2>
      <p class="text-muted max-w-2xl mx-auto">
        Practical thinking on digital transformation, automation, and building
        businesses that scale.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {posts.map((post) => (
        <article class="group">
          <div class="bg-gradient-to-br from-light to-white rounded-2xl p-6 border border-gray-100 group-hover:border-primary/20 group-hover:shadow-md transition-all duration-300 h-full flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xs font-medium px-3 py-1 bg-highlight/10 text-highlight rounded-full">
                {post.category}
              </span>
              <span class="text-xs text-muted">{post.readTime}</span>
            </div>

            <h3 class="text-lg font-semibold text-primary mb-3 group-hover:text-accent transition-colors">
              {post.title}
            </h3>

            <p class="text-muted text-sm leading-relaxed mb-4 flex-grow">
              {post.excerpt}
            </p>

            <div class="flex items-center justify-between pt-4 border-t border-gray-100">
              <span class="text-xs text-muted">{post.date}</span>
              <span class="text-sm font-medium text-primary group-hover:text-highlight transition-colors">
                Read more &rarr;
              </span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
